# Quiz Converter Backend Configuration - Example File
# 
# SETUP INSTRUCTIONS:
# 1. Run: python setup_env.py
# 2. This creates .env.local with your Gemini API key
# 3. .env.local is NOT tracked by Git (it's safe!)
#
# OR manually:
# 1. Copy this file to .env.local
# 2. Fill in GEMINI_API_KEY value
# 3. Run: python main.py

# Database Configuration
# For SQLite (default): sqlite+aiosqlite:///./quiz_converter.db
DATABASE_URL=sqlite+aiosqlite:///./quiz_converter.db

# Server Configuration
DEBUG=False
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000"]

# File Upload Configuration
TEMP_DIR=./temp
MAX_FILE_SIZE=52428800

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256

# Google Gemini API (REQUIRED for real AI analysis, optional for mock mode)
# Get your key from: https://aistudio.google.com/app/apikey
# If not set, the app will use mock predictions for testing
GEMINI_API_KEY=your-gemini-api-key-here

# Logging
LOG_LEVEL=INFO

