# Quiz Converter Backend Configuration - Example File
# Copy this to .env and update values for your environment

# Database Configuration
# For SQLite (default): sqlite+aiosqlite:///./quiz_converter.db
# For SQLite with absolute path: sqlite+aiosqlite:////absolute/path/to/database.db
DATABASE_URL=sqlite+aiosqlite:///./quiz_converter.db

# Server Configuration
# Set DEBUG=False for production
DEBUG=False
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# CORS Configuration
# Update with your frontend domain for production
# Example: ["https://yourdomain.com", "https://app.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000"]

# File Upload Configuration
TEMP_DIR=./temp
MAX_FILE_SIZE=52428800

# Security
# Change these values in production!
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
